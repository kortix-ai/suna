# Copy to terraform.tfvars (gitignored) and fill in. Secrets stay out of git.
#
# Supply Cloudflare creds via env so they never touch disk:
#   export TF_VAR_cloudflare_api_token=...
#   export TF_VAR_cloudflare_zone_id=...

aws_region = "us-west-2"

# PIN prod to an immutable release tag/sha (not :latest).
api_image      = "ghcr.io/kortix-ai/kortix-api:vX.Y.Z"
container_port = 8000

api_environment = {
  ENV_MODE                  = "cloud"
  KORTIX_URL                = "https://api.kortix.com"
  ALLOWED_SANDBOX_PROVIDERS = "daytona"
  # prod non-secret config ...
}

# Secret env vars -> Secrets Manager / SSM ARNs (prod secret bundle).
api_secrets = {
  # API_KEY_SECRET            = "arn:aws:secretsmanager:...:API_KEY_SECRET::"
  # SUPABASE_SERVICE_ROLE_KEY = "arn:aws:secretsmanager:...:SUPABASE_SERVICE_ROLE_KEY::"
  # ... etc.
}
