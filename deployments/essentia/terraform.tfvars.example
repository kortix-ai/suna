# The live essentia deployment uses the defaults baked into variables.tf
# (domain, admin_email, selfhost-rc tag, dev CLI channel, daily backups
# retaining 10, default VPC/subnet in Essentia's account) — this file exists
# for parity with the other terraform roots and as a template if this ever
# needs re-applying from a clean checkout. No secrets here: DAYTONA_API_KEY
# (Essentia's OWN key, never Kortix's) etc. are set post-apply via
# `kortix self-host secrets set` over SSM, never as Terraform inputs.

aws_region  = "us-east-1"
domain      = "essentia.kortix.cloud"
admin_email = "marko@kortix.ai,marko@kortix.com"
