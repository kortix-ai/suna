# The live vps-demo deployment uses the defaults baked into variables.tf
# (domain, admin_email, selfhost-rc tag, dev CLI channel, daily backups
# retaining 10, manual Cloudflare DNS — no zone_id) — this file exists for
# parity with the other terraform roots and as a template if this ever needs
# re-applying from a clean checkout. No secrets here: DAYTONA_API_KEY etc. are
# set post-apply via `kortix self-host secrets set` over SSM, never as
# Terraform inputs.

aws_region  = "us-east-1"
domain      = "ec2-vps-demo.kortix.cloud"
admin_email = "marko@kortix.ai,marko@kortix.com"
