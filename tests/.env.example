# Kortix test suite — environment template.
# Copy to tests/.env and fill in. tests/.env is gitignored; THIS file is committed.
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │ SAFETY: point everything at DEV or a dedicated STAGING/local stack.       │
# │ NEVER prod (kortix.com / api.kortix.com). The ke2e suite WRITES test data │
# │ through the API. Migration/integration DB tests are ephemeral and ignore  │
# │ all of the URLs below.                                                     │
# └─────────────────────────────────────────────────────────────────────────┘

# ─── ke2e — full functional / API suite (the 283 flows) ──────────────────────
# Same names the GitHub Actions `e2e.yml` workflow uses — copy from repo secrets.
KE2E_API_URL=https://dev-api.kortix.com/v1   # leave as-is (dev)

# REQUIRED (3) — copy the DEV values. Source: repo GitHub Actions secrets
# (DEV_SUPABASE_*), or Supabase dashboard for the dev project → Settings → API.
KE2E_SUPABASE_URL=                  # = DEV_SUPABASE_URL
KE2E_SUPABASE_ANON_KEY=            # = DEV_SUPABASE_ANON_KEY
KE2E_SUPABASE_SERVICE_ROLE_KEY=   # = DEV_SUPABASE_SERVICE_ROLE_KEY (mints the synthetic test users)
KE2E_LIVE_CONFIRM=1               # leave as-is — acknowledges a live (non-prod) target

# OPTIONAL — flows needing these self-skip if unset:
KE2E_ADMIN_TOKEN=                # = DEV_KORTIX_ADMIN_API_KEY (platform-admin flows)
KE2E_DATABASE_URL=               # = DEV_DATABASE_URL (a few admin/billing verify flows)

# NOT NEEDED — the suite mints its own owner via the service-role key. Leave blank.
KE2E_OWNER_EMAIL=
KE2E_OWNER_PASSWORD=

# ─── API + smoke lanes (standalone examples) ─────────────────────────────────
API_BASE_URL=http://localhost:8008/v1

# ─── Playwright: e2e / visual / accessibility ────────────────────────────────
E2E_BASE_URL=https://dev.kortix.com

# ─── Contract (Pact) ─────────────────────────────────────────────────────────
PROVIDER_BASE_URL=http://localhost:8008
# Optional — set to publish/verify against a Pact Broker instead of local files:
PACT_BROKER_BASE_URL=
PACT_BROKER_TOKEN=

# ─── Performance (k6) ────────────────────────────────────────────────────────
# Use a DEDICATED staging target — do not load-test shared dev/prod.
BASE_URL=http://localhost:8008/v1
AUTH_TOKEN=                         # optional bearer for authenticated load

# ─── Security DAST (ZAP + Schemathesis) ──────────────────────────────────────
# Dedicated/staging/local ONLY. The runner refuses URLs containing prod/production.
TARGET_URL=

# ─── Migration / DB tests (ephemeral container — defaults are fine) ───────────
# Name MUST contain "test" (guarded). These never touch a real DB.
TEST_DB_NAME=kortix_test
TEST_DB_USER=kortix_test
TEST_DB_PASSWORD=kortix_test
TEST_DB_PORT=55432

# ─── Misc knobs ──────────────────────────────────────────────────────────────
MIN_COVERAGE=80                     # quality-gate coverage threshold
# SKIP_DOCKER_TESTS=1               # force-skip docker-dependent integration tests
# QA_TARGET_URL=                    # staging target used by CI nightly perf/DAST
