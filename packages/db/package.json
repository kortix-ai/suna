{
  "name": "@kortix/db",
  "version": "1.0.0",
  "description": "Kortix Database - Drizzle ORM schemas and client",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/legacy": "./src/schema/legacy/index.ts",
    "./schema/legacy/schema": "./src/schema/legacy/schema.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:studio": "bunx drizzle-kit studio",
    "db:migrate:new": "bun scripts/migrate.ts new",
    "db:migrate:generate": "bun scripts/migrate.ts generate",
    "db:migrate:status": "bun scripts/migrate.ts status",
    "db:migrate:up": "bun scripts/migrate.ts up",
    "db:migrate:verify": "bun scripts/migrate.ts verify"
  },
  "dependencies": {
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "bun-types": "^1.3.12",
    "typescript": "^5.4.0"
  }
}
