{
  "name": "@kortix/db",
  "version": "1.0.0",
  "description": "Kortix Database - Drizzle ORM schemas and client",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./schema": "./src/schema/index.ts",
    "./schema/legacy": "./src/schema/legacy/index.ts",
    "./schema/legacy/schema": "./src/schema/legacy/schema.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:studio": "bunx drizzle-kit studio",
    "migrate": "bun scripts/migrate.ts up",
    "migrate:status": "bun scripts/migrate.ts status",
    "migrate:down": "bun scripts/migrate.ts down",
    "migrate:fake": "bun scripts/migrate.ts fake",
    "migrate:create": "node-pg-migrate create -m migrations -j sql --migration-filename-format utc",
    "migrate:generate": "bun scripts/generate.ts",
    "migrate:lint": "bun scripts/lint-migrations.ts"
  },
  "dependencies": {
    "dotenv": "^16",
    "dotenv-expand": "^12",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "node-pg-migrate": "^8",
    "pg": "^8",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "bun-types": "^1.3.12",
    "typescript": "^5.4.0"
  }
}
