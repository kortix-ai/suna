        "issue_number": { "type": "number", "x-in": "path", "description": "The PR or issue number." },
        "body": { "type": "object", "description": "Request body, e.g. { \"body\": \"<markdown comment>\" }." }
      },
      "required": ["owner", "repo", "issue_number", "body"]
    }
  },
  {
