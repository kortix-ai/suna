  {
    "name": "issues.createComment",
    "method": "POST",
    "path": "/repos/{owner}/{repo}/issues/{issue_number}/comments",
    "description": "Create a comment on an issue or pull request (PRs are issues for this endpoint). Use for posting a review or preview comment.",
    "inputSchema": {
      "type": "object",
      "properties": {
