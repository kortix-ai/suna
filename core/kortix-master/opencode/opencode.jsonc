{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "autoupdate": false,
  "disabled_providers": ["opencode"],
  "default_agent": "kortix",
  "agent": {
    "build": { "disable": true },
    "plan": { "disable": true }
  },
  "provider": {
    "kortix": {
      "npm": "@ai-sdk/openai-compatible",
      "env": ["KORTIX_TOKEN", "KORTIX_API_URL"],
      "options": {
        "baseURL": "{env:KORTIX_API_URL}/v1/router",
        "apiKey": "{env:KORTIX_TOKEN}"
      },
      "models": {
        "minimax-m27": {
          "name": "MiniMax M2.7",
          "id": "minimax/minimax-m2.7",
          "family": "kortix",
          "cost": { "input": 0.30, "output": 1.20 },
          "limit": { "context": 204800, "output": 131072 }
        },
        "glm-turbo": {
          "name": "GLM-5 Turbo",
          "id": "z-ai/glm-5-turbo",
          "family": "kortix",
          "cost": { "input": 1.20, "output": 4.00 },
          "limit": { "context": 202752, "output": 131072 }
        },
        "kimi": {
          "name": "Kimi K2.5",
          "id": "moonshotai/kimi-k2.5",
          "family": "kortix",
          "cost": { "input": 0.45, "output": 2.20 },
          "limit": { "context": 262144, "output": 65535 }
        },
        "minimax": {
          "name": "MiniMax M2.5",
          "id": "minimax/minimax-m2.5",
          "family": "kortix",
          "cost": { "input": 0.20, "output": 1.17 },
          "limit": { "context": 196608, "output": 65536 }
        }
      }
    },
    "avian": {
      "npm": "@ai-sdk/openai-compatible",
      "env": ["AVIAN_API_KEY"],
      "options": {
        "baseURL": "https://api.avian.io/v1",
        "apiKey": "{env:AVIAN_API_KEY}"
      },
      "models": {
        "deepseek-v3.2": {
          "name": "DeepSeek V3.2",
          "id": "deepseek-v3.2",
          "family": "avian",
          "cost": { "input": 0.14, "output": 0.28 },
          "limit": { "context": 163840, "output": 16384 }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "id": "kimi-k2.5",
          "family": "avian",
          "cost": { "input": 0.14, "output": 0.28 },
          "limit": { "context": 131072, "output": 16384 }
        },
        "glm-5": {
          "name": "GLM-5",
          "id": "glm-5",
          "family": "avian",
          "cost": { "input": 0.25, "output": 0.50 },
          "limit": { "context": 131072, "output": 16384 }
        },
        "minimax-m2.5": {
          "name": "MiniMax M2.5",
          "id": "minimax-m2.5",
          "family": "avian",
          "cost": { "input": 0.15, "output": 0.30 },
          "limit": { "context": 1048576, "output": 16384 }
        }
      }
    }
  },
  "plugin": [
    "./plugin/kortix-system/kortix-system.ts"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    }
  }
}
