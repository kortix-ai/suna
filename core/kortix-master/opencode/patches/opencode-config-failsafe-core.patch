+export type ConfigProblem = DeepMutable<Schema.Schema.Type<typeof ConfigProblem>>
+
+export const Status = Schema.Struct({
+  valid: Schema.Boolean,
+  loadedSources: Schema.mutable(Schema.Array(Schema.String)),
+  skippedSources: Schema.mutable(Schema.Array(Schema.String)),
+  problems: Schema.mutable(Schema.Array(ConfigProblem)),
+})
+  .annotate({ identifier: "ConfigStatus" })
+  .pipe(
+    withStatics((s) => ({
+      zod: zod(s).meta({ ref: "ConfigStatus" }) as unknown as z.ZodType<DeepMutable<Schema.Schema.Type<typeof s>>>,
+    })),
+  )
+export type Status = DeepMutable<Schema.Schema.Type<typeof Status>>
+
+function createStatus(): Status {
+  return {
+    valid: true,
+    loadedSources: [],
+    skippedSources: [],
+    problems: [],
+  }
+}
+
+function pushUnique(list: string[], value: string) {
+  if (!list.includes(value)) list.push(value)
+}
+
+function sourceExists(source: string) {
+  if (source === "OPENCODE_CONFIG_CONTENT") return true
+  if (source.startsWith("http://") || source.startsWith("https://")) return true
+  return existsSync(source)
+}
+
+function classifyScope(source: string, scope?: ConfigProblemScope): ConfigProblemScope {
+  if (scope) return scope
+  if (source === "OPENCODE_CONFIG_CONTENT") return "env"
+  if (source.startsWith("http://") || source.startsWith("https://")) return "remote"
+  return "local"
+}
+
+function toProblem(source: string, error: unknown, scope?: ConfigProblemScope): ConfigProblem {
+  if (JsonError.isInstance(error)) {
+    return {
+      source,
+      scope: classifyScope(source, scope),
+      kind: "json",
+      message: error.data.message,
+    }
+  }
+
+  if (InvalidError.isInstance(error)) {
+    const message = error.data.message ?? error.data.issues?.[0]?.message
+    return {
+      source,
+      scope: classifyScope(source, scope),
+      kind: message?.includes("bad file reference") ? "substitution" : "schema",
+      message,
+      issues: error.data.issues,
+    }
+  }
+
+  return {
+    source,
+    scope: classifyScope(source, scope),
+    kind: "schema",
+    message: error instanceof Error ? error.message : String(error),
+  }
+}
+
+function isSoftConfigError(error: unknown): error is InstanceType<typeof JsonError> | InstanceType<typeof InvalidError> {
+  return JsonError.isInstance(error) || InvalidError.isInstance(error)
