+
+export const ConfigProblemKind = Schema.Literals(["json", "schema", "substitution"]).annotate({
+  identifier: "ConfigProblemKind",
+})
+export type ConfigProblemKind = Schema.Schema.Type<typeof ConfigProblemKind>
+
+export const ConfigProblem = Schema.Struct({
+  source: Schema.String,
+  scope: ConfigProblemScope,
+  kind: ConfigProblemKind,
+  message: Schema.optional(Schema.String),
+  issues: Schema.optional(Schema.mutable(Schema.Array(Schema.Unknown))),
+})
