# suna is itself a Kortix project: its root .kortix/ (Dockerfile + opencode
# config dir) is committed and synced via git, so cloud sessions clone the real
# config. Only the per-clone link state stays out. Other vendored .kortix dirs
# stay ignored further down.
.kortix/link.json
apps/kortix-v0/.local/
apps/api/.kortix-data/
apps/api/.sandbox-auth-token.json
core/kortix-master/opencode/.kortix/
**/.buildx-cache/

.nx/
.pulumi
.pulumi/
.vercel


kortix
kortix-darwin-arm64
kortix-darwin-x64
kortix-linux-x64
kortix-linux-arm64
