# kortix-api — required env vars for cloud
#
# This file lists ONLY what the server actually needs to boot and run a
# cloud deployment. Every var below is validated by src/config.ts and
# the server will refuse to start (or warn loudly) if missing.
#
# For optional knobs (LLM provider keys, tunnel tuning, abuse limits,
# Mailtrap, BetterStack, Pipedream, GitHub App, Slack, Freestyle, etc.)
# see src/config.ts — they all have sane defaults or degrade gracefully.

# Master switch — turns on real billing (Stripe + credit ledger), makes
# KORTIX_URL fatal-required, locks the proxy behind a kortix_ token, and
# hides /v1/setup. Leave false for self-host / dev.
KORTIX_BILLING_INTERNAL_ENABLED=true
PORT=8008

# Database
DATABASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 64-char hex — HMAC secret for API key hashing
API_KEY_SECRET=

# Public origin of this API — required in cloud, used for sandbox routing
KORTIX_URL=

# ── Sandbox providers ────────────────────────────────────────────────────────
# Which provider(s) run sessions. Comma-separated; the FIRST is the default for
# new sessions. Known: daytona, platinum, local_docker. Each listed provider's
# keys below are then REQUIRED (the API refuses to start otherwise).
ALLOWED_SANDBOX_PROVIDERS=daytona

# Daytona — managed cloud. Required when ALLOWED_SANDBOX_PROVIDERS includes daytona.
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
DAYTONA_TARGET=

# Platinum — our Cloud Hypervisor microVM platform. Required when
# ALLOWED_SANDBOX_PROVIDERS includes platinum. API key is a pt_live_… key;
# API_URL is the control-plane base (https://api.platinum.dev); TEMPLATE is a
# ready Platinum template id to boot sessions from (e.g. kortix-computer), used
# when a session hasn't built its own per-project template.
# To run sessions on Platinum: set ALLOWED_SANDBOX_PROVIDERS=platinum + these.
PLATINUM_API_KEY=
PLATINUM_API_URL=https://api.platinum.dev
PLATINUM_TEMPLATE=

# Stripe — required because ENV_MODE=cloud implies billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Tunnel — HMAC secret for reverse-tunnel signing (TUNNEL_ENABLED defaults true)
TUNNEL_SIGNING_SECRET=

# OpenRouter — primary LLM route AND the managed LLM gateway (/v1/llm); server
# boots but LLM calls 401 without it
OPENROUTER_API_KEY=

# Managed LLM gateway (/v1/llm) — the `kortix` OpenCode provider routes sandbox
# model calls here. Off by default; uses OPENROUTER_API_KEY above when on.
LLM_GATEWAY_ENABLED=false

# ─── Cloud essentials (optional — server boots without them, features won't work) ───

# GitHub App — without these, project repo creation + session branching fall back
# to a PAT (KORTIX_GITHUB_TOKEN + KORTIX_GITHUB_OWNER) which is local/self-host only
KORTIX_GITHUB_APP_ID=
KORTIX_GITHUB_APP_PRIVATE_KEY=
KORTIX_GITHUB_APP_SLUG=

# Pipedream Connect — powers 1-click connectors; connector flows are dead without it
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_ENVIRONMENT=production

# Mailtrap — provisioning "workspace ready" emails; silently skipped without token
MAILTRAP_API_TOKEN=

# Better Stack — error tracking + structured logs; falls back to stdout without these
BETTERSTACK_API_LOG_TOKEN=
BETTERSTACK_API_LOG_HOST=
BETTERSTACK_API_SENTRY_DSN=
