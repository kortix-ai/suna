# ===========================================
# Kortix Backend API Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Environment Mode
# ===========================================
# Options: local, staging, production
ENV_MODE=local

# ===========================================
# Supabase Configuration (Primary Database)
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ===========================================
# Convex Configuration (Alternative Data Layer)
# ===========================================
# Convex can be used as an alternative to Supabase for the data layer
# Set both CONVEX_URL and CONVEX_API_KEY to enable Convex integration
# If configured, USE_CONVEX will be True and Convex will be used for data operations
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_API_KEY=your_convex_api_key_here

# ===========================================
# Redis Configuration
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_MAX_CONNECTIONS=300
REDIS_SSL=true

# ===========================================
# LLM Provider Configuration
# ===========================================
# Main LLM provider: bedrock, anthropic, minimax, grok, openai
MAIN_LLM=anthropic

# Optional: Override default model for selected provider
# MAIN_LLM_MODEL=anthropic/claude-sonnet-4-20250514

# LLM API Keys (configure at least one)
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
XAI_API_KEY=your_xai_api_key
GEMINI_API_KEY=your_gemini_api_key

# AWS Bedrock (optional)
AWS_BEARER_TOKEN_BEDROCK=your_aws_bearer_token

# ===========================================
# Search & External APIs
# ===========================================
TAVILY_API_KEY=your_tavily_api_key
EXA_API_KEY=your_exa_api_key
SERPER_API_KEY=your_serper_api_key
FIRECRAWL_API_KEY=your_firecrawl_api_key
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key

# ===========================================
# Sandbox Configuration
# ===========================================
DAYTONA_API_KEY=your_daytona_api_key
DAYTONA_SERVER_URL=https://your-daytona-server.com
DAYTONA_TARGET=your_target

# ===========================================
# Stripe Configuration
# ===========================================
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ===========================================
# RevenueCat Configuration (Mobile IAP)
# ===========================================
REVENUECAT_WEBHOOK_SECRET=your_revenuecat_webhook_secret
REVENUECAT_API_KEY=your_revenuecat_api_key

# ===========================================
# Email Configuration
# ===========================================
RESEND_API_KEY=your_resend_api_key

# ===========================================
# Observability (LangFuse)
# ===========================================
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# ===========================================
# MCP & Integrations
# ===========================================
COMPOSIO_API_KEY=your_composio_api_key
COMPOSIO_WEBHOOK_SECRET=your_composio_webhook_secret
MCP_CREDENTIAL_ENCRYPTION_KEY=your_encryption_key

# ===========================================
# Webhooks
# ===========================================
WEBHOOK_BASE_URL=https://your-domain.com
TRIGGER_WEBHOOK_SECRET=your_webhook_secret
SUPABASE_WEBHOOK_SECRET=your_supabase_webhook_secret

# ===========================================
# Voice (Vapi)
# ===========================================
VAPI_PRIVATE_KEY=your_vapi_private_key
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id
VAPI_SERVER_URL=https://your-server.com

# ===========================================
# Memory & Knowledge Base
# ===========================================
ENABLE_MEMORY=false
ENABLE_KNOWLEDGE_BASE=true
ENABLE_USER_CONTEXT=true
MEMORY_EMBEDDING_PROVIDER=openai
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EXTRACTION_MODEL=kortix/basic
VOYAGE_API_KEY=your_voyage_api_key

# ===========================================
# Analytics
# ===========================================
GA_PROPERTY_ID=your_ga_property_id
GA_CREDENTIALS_JSON=path/to/credentials.json
VERCEL_DRAIN_SECRET=your_vercel_drain_secret

# ===========================================
# Frontend URL
# ===========================================
FRONTEND_URL=http://localhost:3000

# ===========================================
# Debug Options (Local/Staging only)
# ===========================================
DEBUG_SAVE_LLM_IO=false
