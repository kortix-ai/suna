# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  kortix-api — Environment Configuration                                    ║
# ║                                                                             ║
# ║  Copy this file:  cp .env.example .env                                     ║
# ║  Then fill in values below. The server validates all vars at startup        ║
# ║  and will refuse to start if required vars are missing.                     ║
# ║                                                                             ║
# ║  Legend:                                                                    ║
# ║    [REQUIRED]     Server will NOT start without this                        ║
# ║    [CONDITIONAL]  Required when a specific feature is enabled               ║
# ║    [OPTIONAL]     Sane default / feature degrades gracefully if missing     ║
# ╚══════════════════════════════════════════════════════════════════════════════╝


# ─── Core [OPTIONAL] ────────────────────────────────────────────────────────

PORT=8008
ENV_MODE=local                          # local | cloud


# ─── Database [REQUIRED] ────────────────────────────────────────────────────

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:64322/postgres


# ─── Supabase [REQUIRED] ────────────────────────────────────────────────────

SUPABASE_URL=http://127.0.0.1:64321
SUPABASE_SERVICE_ROLE_KEY=              # from `supabase status` or Supabase dashboard


# ─── Security [REQUIRED] ────────────────────────────────────────────────────

API_KEY_SECRET=                         # 64-char hex string for HMAC hashing API keys


# ─── Internal Deployment Controls [OPTIONAL] ────────────────────────────────
# Safe defaults for self-hosted — only change for Kortix Cloud.

# INTERNAL_KORTIX_ENV=dev               # dev | staging | prod
# KORTIX_BILLING_INTERNAL_ENABLED=false # optional override; ENV_MODE=cloud implies billing
# KORTIX_ROUTER_INTERNAL_ENABLED=false


# ─── Sandbox [CONDITIONAL] ──────────────────────────────────────────────────
# Daytona is the only supported provider. The list shape is preserved so a
# new provider can land without breaking deployed envs.
ALLOWED_SANDBOX_PROVIDERS=daytona

# Daytona credentials — required:
# DAYTONA_API_KEY=
# DAYTONA_SERVER_URL=
# DAYTONA_TARGET=
# Snapshots are built per-project from each repo's .kortix/Dockerfile by
# apps/api/src/snapshots/builder.ts. There is no shared snapshot env var.

# KORTIX_URL=                           # base URL for sandbox routing (optional)


# ─── Integrations / Pipedream [CONDITIONAL] ──────────────────────────────────
# Required when INTEGRATION_AUTH_PROVIDER=pipedream (the default).
# Get credentials at: https://pipedream.com/connect

INTEGRATION_AUTH_PROVIDER=pipedream
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_ENVIRONMENT=development       # development | production

# Direct provider OAuth for connectors/channels that do not use Pipedream.
# JSON map keyed by app slug. Values include authorization_url, token_url,
# client_id/client_secret or client_id_env/client_secret_env, scopes, and
# optional account_id_path/account_name_path for token response metadata.
# KORTIX_DIRECT_OAUTH_APPS='{"slack":{"provider":"slack","app_name":"Slack","authorization_url":"https://slack.com/oauth/v2/authorize","token_url":"https://slack.com/api/oauth.v2.access","client_id_env":"SLACK_CLIENT_ID","client_secret_env":"SLACK_CLIENT_SECRET","scopes":["chat:write","channels:history"],"account_id_path":"team.id","account_name_path":"team.name"}}'
# KORTIX_OAUTH_RELAY_ALLOWED_ORIGINS=https://self-host.example.com


# ─── Scheduler / Cron [OPTIONAL] ────────────────────────────────────────────

SCHEDULER_ENABLED=true
CRON_TICK_SECRET=                       # secret for pg_cron tick endpoint
# CRON_API_URL is auto-derived from PORT + DOCKER_HOST. Override only if needed:
# CRON_API_URL=http://host.docker.internal:8008


# ─── LLM Providers [OPTIONAL — cloud routing] ───────────────────────────────
# In cloud mode, the router proxies LLM requests using these Kortix-owned keys.
# Not needed for local mode — sandboxes use their own keys directly.
# Custom API URLs can be set per provider (defaults to official endpoints).

OPENROUTER_API_KEY=                     # primary LLM route — warns if empty
# OPENROUTER_API_URL=https://openrouter.ai/api/v1
# ANTHROPIC_API_KEY=
# ANTHROPIC_API_URL=https://api.anthropic.com/v1
# OPENAI_API_KEY=
# OPENAI_API_URL=https://api.openai.com/v1
# XAI_API_KEY=
# XAI_API_URL=https://api.x.ai/v1
# GEMINI_API_KEY=
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
# GROQ_API_KEY=
# GROQ_API_URL=https://api.groq.com/openai/v1
# AWS_BEARER_TOKEN_BEDROCK=


# ─── Search & Proxy Providers [OPTIONAL] ────────────────────────────────────
# Features degrade gracefully if keys are missing.
# Custom API URLs can be set per provider (defaults to official endpoints).

# TAVILY_API_KEY=
# TAVILY_API_URL=https://api.tavily.com
# SERPER_API_KEY=
# SERPER_API_URL=https://google.serper.dev
# FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=https://api.firecrawl.dev
# REPLICATE_API_TOKEN=
# REPLICATE_API_URL=https://api.replicate.com
# CONTEXT7_API_KEY=
# CONTEXT7_API_URL=https://context7.com
# FREESTYLE_API_KEY=
# FREESTYLE_API_URL=https://api.freestyle.sh


# ─── Billing [CONDITIONAL — required when ENV_MODE=cloud or KORTIX_BILLING_INTERNAL_ENABLED=true] ─

# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# REVENUECAT_API_KEY=
# REVENUECAT_WEBHOOK_SECRET=


# ─── Channels [OPTIONAL] ────────────────────────────────────────────────────

# CHANNELS_ENABLED=true
# CHANNELS_PUBLIC_URL=
# CHANNELS_CREDENTIAL_KEY=              # 64-char hex for AES-256-GCM credential encryption


# ─── Session Pruning [OPTIONAL] ─────────────────────────────────────────────
# LLM context window management. All have sane defaults.

# SESSION_PRUNING_ENABLED=true
# SESSION_PRUNING_TTL_MS=300000         # idle time before pruning (default 5 min)
# SESSION_PRUNING_KEEP_LAST=3           # trailing turns protected from pruning
# SESSION_PRUNING_SOFT_RATIO=0.3        # context fill ratio triggering soft-trim
# SESSION_PRUNING_HARD_RATIO=0.5        # context fill ratio triggering hard-clear
# SESSION_PRUNING_MIN_CHARS=50000       # min prunable chars before hard-clear
# SESSION_PRUNING_SOFT_MAX=4000         # tool result size threshold for soft-trim
# SESSION_PRUNING_SOFT_HEAD=1500        # chars kept from start during soft-trim
# SESSION_PRUNING_SOFT_TAIL=1500        # chars kept from end during soft-trim
# SESSION_PRUNING_HARD_ENABLED=true
# SESSION_PRUNING_HARD_PLACEHOLDER=[Old tool result content cleared]


# ─── Frontend [OPTIONAL] ────────────────────────────────────────────────────

# FRONTEND_URL=http://localhost:3000


# ─── Tunnel [OPTIONAL] ──────────────────────────────────────────────────────
# Reverse-tunnel to user's local machine. All have sane defaults.

TUNNEL_SIGNING_SECRET=              # Required — HMAC secret for tunnel signing key derivation
# TUNNEL_ENABLED=true
# TUNNEL_HEARTBEAT_INTERVAL_MS=30000
# TUNNEL_HEARTBEAT_MAX_MISSED=3
# TUNNEL_RPC_TIMEOUT_MS=30000
# TUNNEL_MAX_FILE_SIZE=10485760         # 10MB
# TUNNEL_PERMISSION_REQUEST_TTL_MS=300000
# TUNNEL_RATE_LIMIT_RPC=100
# TUNNEL_RATE_LIMIT_PERM_REQUEST=20
# TUNNEL_RATE_LIMIT_WS_CONNECT=5
# TUNNEL_RATE_LIMIT_PERM_GRANT=30
# TUNNEL_MAX_WS_MESSAGE_SIZE=5242880    # 5MB


# ─── Abuse Controls [OPTIONAL] ──────────────────────────────────────────────

# KORTIX_INVITE_ACCEPT_REQS_PER_MIN=20
# KORTIX_LLM_ROUTER_REQS_PER_MIN_FREE=60
# KORTIX_LLM_ROUTER_REQS_PER_MIN_PAID=600
# KORTIX_PROXY_REQS_PER_MIN=600
# KORTIX_MAX_CONCURRENT_SESSIONS_FREE=1
# KORTIX_MAX_CONCURRENT_SESSIONS_PAID=5
# KORTIX_TRIGGER_MAX_PROVISIONING_SESSIONS_PER_PROJECT=3
# KORTIX_TRIGGER_SCHEDULER_ENABLED=true
# KORTIX_TRIGGER_SCHEDULER_INTERVAL_MS=60000


# ─── Slack [OPTIONAL] ───────────────────────────────────────────────────────

# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=


# ─── Email Notifications / Mailtrap [OPTIONAL] ──────────────────────────────
# Sends a "workspace ready" email when provisioning completes.
# Get your token at: https://mailtrap.io/sending/domains

# MAILTRAP_API_TOKEN=
# MAILTRAP_FROM_EMAIL=noreply@kortix.com
# MAILTRAP_FROM_NAME=Kortix


# ─── Version / GitHub [OPTIONAL] ────────────────────────────────────────────

# SANDBOX_VERSION=                      # dev override: force a specific sandbox version
# GITHUB_TOKEN=                         # authenticated GitHub API for changelog fetching
# SANDBOX_AUTO_UPDATE_ENABLED=          # cloud default: true; local default: false unless explicitly set

# ─── Kortix Projects / GitHub [OPTIONAL] ────────────────────────────────────
# Production path: each account installs the Kortix GitHub App. Repo creation,
# session branch creation, and sandbox clone tokens are minted from that
# account installation. The PAT envs below are local/self-host fallback only
# when the GitHub App env is not configured.

# KORTIX_GITHUB_APP_ID=                 # GitHub App id
# KORTIX_GITHUB_APP_PRIVATE_KEY=        # PEM private key; \n escaped is accepted
# KORTIX_GITHUB_APP_SLUG=               # app slug for install URL
# KORTIX_GITHUB_TOKEN=                  # local fallback PAT with repo scope
# KORTIX_GITHUB_OWNER=                  # local fallback owner namespace
# KORTIX_GIT_CACHE_DIR=                 # bare repo mirror cache (default /tmp/kortix/git-cache)
# KORTIX_GIT_REFRESH_INTERVAL_MS=       # mirror refresh interval in ms (default 60000)

# ─── Kortix Sessions → Daytona ──────────────────────────────────────────────
# Each project session is one Daytona sandbox. The snapshot is built per
# project from the repo's .kortix/Dockerfile by apps/api/src/snapshots/builder.ts;
# the layered runtime adds OpenCode, the kortix-agent binary, and a boot
# script that reads the env vars below to `git clone --branch
# $KORTIX_PROJECT_BRANCH $KORTIX_PROJECT_REPO_URL` and launch OpenCode.
# The token below is injected at sandbox-create time so the boot script
# can clone private repos.
#
# Required: DAYTONA_API_KEY, DAYTONA_SERVER_URL, DAYTONA_TARGET.
# Add `daytona` to ALLOWED_SANDBOX_PROVIDERS for the legacy /instances flow
# (sessions ignore that flag and always go to Daytona).
#
# Env vars injected into every session sandbox at create time:
#   KORTIX_PROJECT_REPO_URL  – git clone target
#   KORTIX_PROJECT_BRANCH    – session branch == session_id (UUID)
#   KORTIX_PROJECT_BASE_REF  – branch the session forked from
#   KORTIX_PROJECT_ID        – project UUID
#   KORTIX_SESSION_ID        – session UUID (== sandbox_id == branch)
#   KORTIX_GITHUB_TOKEN      – short-lived GitHub token for cloning private repos
#   KORTIX_TOKEN             – sandbox→api auth (existing)


# ─── Networking [OPTIONAL] ──────────────────────────────────────────────────

# CORS_ALLOWED_ORIGINS=                 # extra CORS origins (comma-separated)


# ─── Better Stack Observability [OPTIONAL] ───────────────────────────────────
# Error tracking + structured logging via Better Stack.
# Features degrade gracefully if not configured.

# BETTERSTACK_API_LOG_TOKEN=            # Logtail source token for structured logs
# BETTERSTACK_API_LOG_HOST=             # Logtail ingesting host (e.g. s1234.us-east-9.betterstackdata.com)
# BETTERSTACK_API_SENTRY_DSN=           # Sentry-compatible DSN for error tracking


# ─── Internal / Advanced [OPTIONAL] ─────────────────────────────────────────

# KORTIX_MASTER_URL=                    # sandbox master URL override
# OPENCODE_URL=                         # OpenCode service URL override
# KORTIX_DATA_DIR=                      # data directory override


# ─── Internal Service Key [AUTO-GENERATED] ──────────────────────────────────
# Auto-generated on first startup if missing. Do not remove once set.

# INTERNAL_SERVICE_KEY=


# ─── JustAVPS [OPTIONAL] ────────────────────────────────────────────────────
# JUSTAVPS_API_URL=https://justavps.com/api/v1
# JUSTAVPS_API_KEY=
# JUSTAVPS_IMAGE_ID=
# JUSTAVPS_WEBHOOK_SECRET=
# JUSTAVPS_DEFAULT_LOCATION=nbg1
# JUSTAVPS_DEFAULT_SERVER_TYPE=pro
