{
  "name": "kortix-api",
  "version": "1.0.0",
  "description": "Kortix API - Unified monolith combining router, billing, platform, cron, and daytona-proxy",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "migration:legacy-sandboxes": "bun run src/scripts/migrate-legacy-sandboxes.ts",
    "typecheck": "tsc --noEmit",
    "test": "for f in src/__tests__/billing/*.test.ts src/__tests__/e2e-*.test.ts src/__tests__/unit-*.test.ts; do bun test \"$f\" || exit 1; done",
    "test:all": "bun run test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.38",
    "@ai-sdk/google": "^3.0.22",
    "@ai-sdk/openai": "^3.0.26",
    "@ai-sdk/openai-compatible": "^2.0.28",
    "@ai-sdk/xai": "^3.0.48",
    "@daytonaio/sdk": "^0.143.0",
    "@kortix/db": "workspace:*",
    "@kortix/shared": "workspace:*",
    "@logtail/node": "^0.5.8",
    "@sentry/bun": "^10.47.0",
    "@supabase/supabase-js": "^2.95.3",
    "agent-tunnel": "workspace:@kortix/agent-tunnel@*",
    "ai": "^6.0.77",
    "croner": "^9.0.0",
    "dockerode": "^4.0.4",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.4.0",
    "postgres": "^3.4.8",
    "stripe": "^14.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/dockerode": "^3.3.35",
    "bun-types": "^1.3.12",
    "typescript": "^5.4.0"
  }
}
