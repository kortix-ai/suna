#!/usr/bin/env bash
set -euo pipefail

# Walk symlinks so this works when invoked via a PATH symlink (npm bin,
# homebrew, manual ln -sf). macOS readlink predates -f, so do it manually.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
ROOT="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

exec bun run "$ROOT/src/index.ts" "$@"
