{
  "name": "@kortix/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Kortix desktop shell — Tauri wrapper around the web app",
  "scripts": {
    "dev": "tauri dev",
    "dev:macos": "tauri build --debug --bundles app && open -n src-tauri/target/debug/bundle/macos/Kortix.app",
    "prepare-dist": "bash scripts/prepare-dist.sh",
    "prepare-icons": "tauri icon src-tauri/icons/source.png",
    "prepare-assets": "pnpm run prepare-dist && pnpm run prepare-icons",
    "build": "pnpm run prepare-assets && tauri build",
    "tauri": "tauri",
    "icons": "tauri icon"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0"
  }
}
