{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.kortix.com/project/v0",
  "title": "Kortix Project",
  "description": "Kortix v0 project manifest. Stored as kortix.toml in any Git repository.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "name"],
  "properties": {
    "schema": {
      "const": "https://schemas.kortix.com/project/v0"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["opencode"]
        },
        "mode": {
          "type": "string",
          "enum": ["ephemeral"]
        },
        "workspace": {
          "type": "string",
          "default": "/workspace"
        },
        "mount": {
          "type": "string",
          "default": "/workspace/.kortix"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "default_branch": {
          "type": "string",
          "default": "main"
        }
      }
    },
    "opencode": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "config_dir": {
          "type": "string",
          "default": ".opencode"
        },
        "config": {
          "type": "string",
          "default": ".opencode/opencode.jsonc"
        }
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "$ref": "#/$defs/envKeys"
        },
        "optional": {
          "$ref": "#/$defs/envKeys"
        }
      }
    }
  },
  "$defs": {
    "envKeys": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z_][A-Z0-9_]*$"
      },
      "uniqueItems": true
    }
  }
}
