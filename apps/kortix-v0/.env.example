# Optional token for private HTTPS GitHub repos.
# SSH remotes and local Git credential helpers work without this.
GITHUB_TOKEN=

# Daytona session execution.
DAYTONA_API_KEY=
DAYTONA_SERVER_URL=
DAYTONA_TARGET=
DAYTONA_SNAPSHOT=
DAYTONA_IMAGE=kortix/computer:dev-latest

# Optional local overrides.
KORTIX_V0_PORT=4310
KORTIX_V0_HOST=127.0.0.1
KORTIX_V0_DATA_DIR=.local
KORTIX_V0_IDLE_TIMEOUT=60
KORTIX_V0_GIT_REFRESH_INTERVAL_MS=60000
KORTIX_V0_SNAPSHOT_PREFIX=kortix-sandbox
KORTIX_V0_OPENCODE_START=bash -lc 'cd /workspace && opencode serve --port 4096'
