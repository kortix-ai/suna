#!/usr/bin/env bash
set -euo pipefail

cmd="${1:-start}"

if [[ "$cmd" == "entrypoint" ]]; then
  cmd="start"
fi

if [[ "$cmd" != "start" ]]; then
  echo "usage: kortix-daemon [start|entrypoint]" >&2
  exit 2
fi

workspace="${KORTIX_WORKSPACE:-/workspace}"
project_root="${KORTIX_PROJECT_ROOT:-${KORTIX_PROJECT_TARGET:-$workspace/.kortix}}"
service_port="${KORTIX_SERVICE_PORT:-4096}"
service_host="${KORTIX_SERVICE_HOST:-0.0.0.0}"
default_config_dir="${KORTIX_DEFAULT_OPENCODE_CONFIG_DIR:-}"

export HOME="${HOME:-$workspace}"
export KORTIX_WORKSPACE="$workspace"
export KORTIX_PROJECT_ROOT="$project_root"
export OPENCODE_FILE_ROOT="${OPENCODE_FILE_ROOT:-/}"

if [[ -f "$project_root/.opencode/opencode.jsonc" ]]; then
  export OPENCODE_CONFIG_DIR="$project_root/.opencode"
elif [[ -n "$default_config_dir" && -f "$default_config_dir/opencode.jsonc" ]]; then
  export OPENCODE_CONFIG_DIR="$default_config_dir"
else
  unset OPENCODE_CONFIG_DIR
fi

unset PORT APP_PORT
mkdir -p "$workspace"
cd "$workspace"

echo "[kortix-daemon] starting OpenCode on ${service_host}:${service_port}"
if [[ -n "${OPENCODE_CONFIG_DIR:-}" ]]; then
  echo "[kortix-daemon] OPENCODE_CONFIG_DIR=$OPENCODE_CONFIG_DIR"
else
  echo "[kortix-daemon] OPENCODE_CONFIG_DIR unset; using OpenCode defaults"
fi

if [[ -x /usr/local/bin/opencode-kortix ]]; then
  exec /usr/local/bin/opencode-kortix serve --port "$service_port" --hostname "$service_host"
fi

if command -v opencode-kortix >/dev/null 2>&1; then
  exec opencode-kortix serve --port "$service_port" --hostname "$service_host"
fi

if command -v opencode >/dev/null 2>&1; then
  exec opencode serve --port "$service_port" --hostname "$service_host"
fi

echo "[kortix-daemon] opencode binary missing" >&2
sleep 3600
