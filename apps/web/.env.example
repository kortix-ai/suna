# Required runtime frontend env
NEXT_PUBLIC_BILLING_ENABLED=false
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_BACKEND_URL=http://localhost:8008/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_KORTIX_PERSONAL_CONTACT=true

# Vercel Edge Config — maintenance notifications [OPTIONAL, local dev uses in-memory fallback]
# EDGE_CONFIG=
# EDGE_CONFIG_ID=
# VERCEL_API_TOKEN=

# Better Stack observability [OPTIONAL]
# Error tracking — Sentry-compatible DSN, tunneled via /monitoring to bypass ad-blockers
# NEXT_PUBLIC_SENTRY_DSN=
# Structured logging — @logtail/next source token + ingesting host
# NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=
# NEXT_PUBLIC_BETTER_STACK_INGESTING_URL=

# Cloud-only personal-contact UI [OPTIONAL, default off]
# Shows the founder's contact widget + the "Personal help" section in the
# Support dialog. Self-hosters should leave this OFF.

