{
  "name": "agentpress",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "dev:frontend": "pnpm --filter Kortix dev",
    "dev:mobile": "pnpm --filter kortix dev",
    "build:frontend": "pnpm --filter Kortix build"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.7",
      "@types/react-dom": "^19.1.7"
    }
  },
  "dependencies": {
    "@babel/types": "^7.28.6",
    "next": "^16.1.4"
  }
}
